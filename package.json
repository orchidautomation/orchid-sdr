{
  "name": "trellis",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "license": "AGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "postinstall": "npm run build:packages",
    "dev": "npm run trellis -- help",
    "build:packages": "npm run build -w @trellis/gtm && npm run build -w @trellis/providers",
    "build": "npm run build:packages",
    "build:all": "npm run build:packages && npm run build:legacy",
    "build:legacy:packages": "npm run build -w @trellis/framework && npm run build -w @trellis/default-sdr && npm run build -w @trellis/convex",
    "build:legacy": "node scripts/fix-rivetkit-engine-runner-protocol.mjs && npm run build:legacy:packages && tsup examples/reference-app/src/index.ts examples/reference-app/src/mcp/trellis-server.ts --format esm --target node22 --outDir dist --clean",
    "start": "npm run trellis -- help",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "trellis": "tsx packages/trellis-cli/src/cli.ts",
    "doctor": "npm run trellis -- doctor",
    "smoke": "npm run trellis -- smoke",
    "verify": "npm run trellis -- verify cloudflare",
    "legacy:dev": "tsx watch examples/reference-app/src/index.ts",
    "legacy:doctor": "tsx examples/reference-app/scripts/doctor.ts",
    "legacy:demo:check": "tsx examples/reference-app/scripts/demo-check.ts",
    "legacy:demo:smoke": "tsx examples/reference-app/scripts/demo-smoke.ts",
    "legacy:validate:prod": "tsx examples/reference-app/scripts/production-validate.ts",
    "legacy:cleanup:stale": "tsx examples/reference-app/scripts/cleanup-stale-data.ts",
    "legacy:discovery:tick": "tsx examples/reference-app/scripts/discovery-tick.ts",
    "legacy:sandbox:probe": "tsx examples/reference-app/scripts/sandbox-probe.ts",
    "legacy:example:closed-won-lookalike": "tsx examples/reference-app/scripts/closed-won-lookalike.ts"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.104",
    "@hono/node-server": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@vercel/sandbox": "^1.10.0",
    "ai": "^6.0.168",
    "convex": "^1.36.1",
    "hono": "^4.12.14",
    "rivetkit": "^2.2.1",
    "sandbox-agent": "^0.4.2",
    "svix": "^1.91.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
