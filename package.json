{
  "name": "trellis",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "license": "AGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch examples/ai-sdr/src/index.ts",
    "build": "tsup examples/ai-sdr/src/index.ts examples/ai-sdr/src/mcp/trellis-server.ts --format esm --target node22 --outDir dist --clean && mkdir -p dist/migrations && cp examples/ai-sdr/src/db/migrations/*.sql dist/migrations/",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ai-sdr": "tsx packages/ai-sdr/src/cli.ts",
    "trellis-plugin:lint": "cd plugins/trellis && pluxx lint",
    "trellis-plugin:validate": "cd plugins/trellis && pluxx validate",
    "trellis-plugin:build": "cd plugins/trellis && pluxx build --target claude-code cursor codex opencode",
    "db:migrate": "tsx examples/ai-sdr/scripts/migrate.ts",
    "doctor": "tsx examples/ai-sdr/scripts/doctor.ts",
    "discovery:tick": "tsx examples/ai-sdr/scripts/discovery-tick.ts",
    "sandbox:probe": "tsx examples/ai-sdr/scripts/sandbox-probe.ts"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.104",
    "@hono/node-server": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@types/pg": "^8.20.0",
    "@vercel/sandbox": "^1.10.0",
    "ai": "^6.0.168",
    "convex": "^1.36.1",
    "hono": "^4.12.14",
    "pg": "^8.16.0",
    "rivetkit": "^2.2.1",
    "sandbox-agent": "^0.4.2",
    "svix": "^1.91.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
