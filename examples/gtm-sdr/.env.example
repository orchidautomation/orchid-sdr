# First deploy only needs Cloudflare auth via wrangler login or CLOUDFLARE_API_TOKEN.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Local client token for protected Trellis routes and demo scripts.
# Also set this as a Worker secret when you deploy protected routes:
# npx wrangler secret put TRELLIS_API_KEY
TRELLIS_API_KEY=

# Active research provider.
FIRECRAWL_API_KEY=

# Optional CRM provider. Setting these enables explicit Attio smoke writes.
ATTIO_API_KEY=
ATTIO_DEFAULT_LIST_ID=
TRELLIS_PROVIDER_SMOKE_TOKEN=
TRELLIS_ATTIO_SMOKE_DOMAIN=
TRELLIS_ATTIO_SMOKE_EMAIL=

# Optional future providers.
APIFY_TOKEN=
APIFY_WEBHOOK_SECRET=
APIFY_BASE_URL=
APIFY_DATASET_LIMIT=
PROSPEO_API_KEY=
PROSPEO_BASE_URL=
HANDOFF_WEBHOOK_URL=
HANDOFF_WEBHOOK_SECRET=

# Optional model override for Flue-backed skills.
# The default uses Cloudflare's proxied GPT-5.5 through the Workers AI binding and AI Gateway.
TRELLIS_MODEL=cloudflare/openai/gpt-5.5
TRELLIS_AI_GATEWAY_ID=default
# Optional only for URL-based `cloudflare-ai-gateway/*` models.
CLOUDFLARE_AI_GATEWAY_TOKEN=
CLOUDFLARE_GATEWAY_ID=default
TRELLIS_SKILL_TIMEOUT_MS=120000
TRELLIS_FOLLOW_UP_DELAY=3 days

# Optional trace export. D1 trace events, Cloudflare logs, and AI Gateway remain the default.
TRELLIS_TRACE_EXPORT_URL=
TRELLIS_TRACE_EXPORT_TOKEN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT_ID=
BRAINTRUST_BASE_URL=
