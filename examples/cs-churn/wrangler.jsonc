{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "trellis-cs-churn",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "TRELLIS_AGENT",
        "class_name": "TrellisAgent"
      }
    ]
  },
  "workflows": [
    {
      "name": "trellis-cs-churn-workflow",
      "binding": "PROSPECT_WORKFLOW",
      "class_name": "ProspectWorkflow"
    }
  ],
  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["TrellisAgent"]
    }
  ],
  "vars": {
    "TRELLIS_MODEL": "cloudflare/openai/gpt-5.5"
  }
}
