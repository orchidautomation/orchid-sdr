{
  "name": "@ai-sdr/default-sdr",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./domain-types": {
      "types": "./src/domain-types.ts",
      "default": "./dist/domain-types.js"
    },
    "./repository-contracts": {
      "types": "./src/repository-contracts.ts",
      "default": "./dist/repository-contracts.js"
    },
    "./repository-factory": {
      "types": "./src/repository-factory.ts",
      "default": "./dist/repository-factory.js"
    },
    "./convex-repository": {
      "types": "./src/convex-repository.ts",
      "default": "./dist/convex-repository.js"
    },
    "./local-smoke-repository": {
      "types": "./src/local-smoke-repository.ts",
      "default": "./dist/local-smoke-repository.js"
    },
    "./mcp-server": {
      "types": "./src/mcp-server.ts",
      "default": "./dist/mcp-server.js"
    },
    "./webhook-bootstrap": {
      "types": "./src/webhook-bootstrap.ts",
      "default": "./dist/webhook-bootstrap.js"
    },
    "./dashboard-bootstrap": {
      "types": "./src/dashboard-bootstrap.ts",
      "default": "./dist/dashboard-bootstrap.js"
    },
    "./dashboard-shell": {
      "types": "./src/dashboard-shell.ts",
      "default": "./dist/dashboard-shell.js"
    },
    "./actor-registry": {
      "types": "./src/actor-registry.ts",
      "default": "./dist/actor-registry.js"
    },
    "./runtime-bindings": {
      "types": "./src/runtime-bindings.ts",
      "default": "./dist/runtime-bindings.js"
    },
    "./runtime-bootstrap": {
      "types": "./src/runtime-bootstrap.ts",
      "default": "./dist/runtime-bootstrap.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/domain-types.ts src/repository-contracts.ts src/repository-factory.ts src/convex-repository.ts src/local-smoke-repository.ts src/mcp-server.ts src/webhook-bootstrap.ts src/dashboard-bootstrap.ts src/dashboard-shell.ts src/actor-registry.ts src/runtime-bindings.ts src/runtime-bootstrap.ts --format esm --target node22 --outDir dist --clean"
  }
}
